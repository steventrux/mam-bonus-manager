# Copia questo file in /etc/mam-bonus-manager/config.env
# poi imposta chmod 600 /etc/mam-bonus-manager/config.env

# Valore del cookie mam_id. Non committare mai questo valore reale.
MAM_ID="INSERISCI_QUI_IL_TUO_MAM_ID"

# Directory di lavoro per cookie, lock e stato wedge.
WORKDIR="/opt/MAM"

# Punti da mantenere come riserva prima di comprare upload.
BUFFER=55000

# 1 abilita acquisto/estensione VIP, 0 disabilita.
VIP=0

# Compra un wedge ogni N ore. 0 = disabilitato.
WEDGE_HOURS=4
WEDGE_COST=50000
WEDGE_RESERVE_AFTER=5000

# Pacchetti upload da comprare, in ordine dal più grande al più piccolo.
UPLOAD_PACKS="100 20 5 1"

# Curl
CURL_TIMEOUT=30
CURL_RETRIES=3
