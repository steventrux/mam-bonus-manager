# Copy this file to /etc/mam-bonus-manager/config.env
# then set: chmod 600 /etc/mam-bonus-manager/config.env

# Value of the mam_id cookie. Never commit the real value.
MAM_ID="PUT_YOUR_MAM_ID_HERE"

# Working directory for cookies, lock file and wedge state.
WORKDIR="/opt/MAM"

# Bonus points to keep as a reserve before buying upload credit.
BUFFER=55000

# Set to 1 to enable VIP purchase/extension, 0 to disable it.
VIP=0

# Buy a wedge every N hours. Set to 0 to disable wedge purchases.
WEDGE_HOURS=4
WEDGE_COST=50000
WEDGE_RESERVE_AFTER=5000

# Upload credit package sizes to buy, from largest to smallest, in GB.
UPLOAD_PACKS="100 20 5 1"

# Curl settings.
CURL_TIMEOUT=30
CURL_RETRIES=3
USER_AGENT="Mozilla/5.0 mam-bonus-manager/1.0.0"
