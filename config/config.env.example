# Configuration schema version. Updated automatically by config migration.
CONFIG_VERSION="1.4.4"

# Copy this file to /etc/mam-bonus-manager/config.env
# then set: chmod 600 /etc/mam-bonus-manager/config.env

# Value of the mam_id cookie. Never commit the real value.
# You can either set MAM_ID directly or store it in MAM_ID_FILE.
MAM_ID="PUT_YOUR_MAM_ID_HERE"
MAM_ID_FILE=""

# Working directory for cookies, lock file, runtime state and purchase history.
# In Docker, use WORKDIR="/config" so cookies/history survive container recreation.
WORKDIR="/opt/MAM"

# Logging.
# VERBOSITY: 0=ERROR, 1=INFO/WARN, 2=DEBUG
VERBOSITY=1
LOG_FILE=""

# Global bonus point reserve.
# Preserved by automated wedge, donation and larger upload-credit purchases.
# It does not block automatic VIP purchases.
# It does not block the minimum configured upload package when the ratio guard allows upload purchases
# and enough points are available for that package.
BONUS_RESERVE_POINTS=30000

# Set to 1 to enable automated VIP purchase/extension, 0 to disable it.
# VIP is only purchased automatically if the account is not VIP, or if VIP expires
# within VIP_THRESHOLD_WEEKS.
# Manual VIP mode supports the documented durations: 4, 8, 12, or max.
VIP=1
VIP_THRESHOLD_WEEKS=11

# Buy a wedge every N hours. Set to 0 to disable automated wedge purchases.
WEDGE_HOURS=0

# MAM currently rejects automated upload purchases below 50GB.
MIN_UPLOAD_GB=50

# Upload credit package sizes to buy, from largest to smallest, in GB.
UPLOAD_PACKS="100 50"

# Optional ratio guard for automated upload credit purchases.
# Upload credit is bought only when the current ratio is below this threshold.
# Set to 0 to disable the ratio guard and keep the previous behavior.
UPLOAD_RATIO_THRESHOLD=2.5

# Optional new-user donations.
# Gift donations are sent through the Playwright/Chromium browser executor.
# The legacy curl/API gift method is intentionally not supported because MAM rejects gifts via API.
DONATIONS=0

# Persistent Chromium profile directory used by the browser gift executor.
# Leave empty to use $WORKDIR/browser-profile.
MAM_BROWSER_PROFILE_DIR=""

# Browser executor timeout in milliseconds.
MAM_BROWSER_TIMEOUT=30000

# MAM web-login email used by the browser gift executor when the browser profile is not already logged in.
# Prefer storing the password in MAM_LOGIN_PASSWORD_FILE.
MAM_LOGIN_EMAIL=""
MAM_LOGIN_PASSWORD_FILE=""

# Points donated to each recipient in automated donation mode.
DONATION_AMOUNT=100

# Maximum number of actual donation recipients per automatic run.
# The scan walks backward until this many eligible candidates are found,
# or until DONATION_SCAN_LOOKBACK is reached.
DONATION_MAX_USERS_PER_RUN=5

# Maximum cumulative points donated to the same user.
# Set to 0 to disable this limit.
DONATION_MAX_POINTS_PER_USER=1000

# Days before the same user can receive another donation.
# Set to 0 to never donate again to the same user.
DONATION_COOLDOWN_DAYS=30

# Donate only to users whose uploaded amount is <= this value.
# Default: 50 GiB. Set to 0 to disable this filter.
DONATION_MAX_RECIPIENT_UPLOADED_BYTES=53687091200

# Local donation history file.
# Leave empty to use $WORKDIR/donations.tsv.
DONATION_STATE_FILE=""

# Advanced donation discovery settings.
# Latest UID discovery automatically starts from the authenticated user UID on the first run.
# After real donations are recorded, it starts from the highest UID in DONATION_STATE_FILE.
DONATION_LATEST_UID_STEP=1000
DONATION_SCAN_LOOKBACK=100

# Delay between UID checks. Use 0 only for short tests.
DONATION_SCAN_DELAY_SECONDS=1

# Curl settings.
CURL_TIMEOUT=30
CURL_RETRIES=3
USER_AGENT="Mozilla/5.0 mam-bonus-manager"

# Optional heartbeat URL, for example Healthchecks.io or Uptime Kuma push monitor.
HEARTBEAT_URL=""

# Optional Telegram daily summary.
# The script stores purchase events in PURCHASE_LOG_FILE and sends at most one
# summary per day for yesterday's purchases.
TELEGRAM_DAILY_SUMMARY=0
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
PURCHASE_LOG_FILE=""
TELEGRAM_SENT_FILE=""